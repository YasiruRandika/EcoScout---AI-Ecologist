# Gemini API key (for local development)
GOOGLE_API_KEY=your-api-key-here

# Access token for deployed app (restricts who can use EcoScout). Leave empty for no auth (local dev).
# Generate with: openssl rand -hex 24
# ECOSCOUT_ACCESS_TOKEN=

# Set to True when deploying to Google Cloud (uses Vertex AI)
# GOOGLE_GENAI_USE_VERTEXAI=True
# GOOGLE_CLOUD_PROJECT=your-project-id

# GCS bucket for media storage
GCS_BUCKET_NAME=ecoscout-media

# Model overrides (defaults are fine)
# ECOSCOUT_MODEL=gemini-live-2.5-flash-native-audio
# IMAGE_MODEL=gemini-3-pro-image-preview
# VIDEO_MODEL=veo-3.1-generate-preview

# Voice selection for native audio output
ECOSCOUT_VOICE=Orus

# Google Maps API key for reverse geocoding (optional, falls back to Nominatim)
# GOOGLE_MAPS_API_KEY=your-maps-api-key
